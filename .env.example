# --- Workiz credentials ---
# Get these from Workiz: Feature Center > enable "Developer API" add-on,
# then Settings > Integrations > Developer
WORKIZ_API_TOKEN=your_workiz_api_token_here
WORKIZ_API_BASE=https://api.workiz.com/api/v1

# --- Server auth ---
# This is a secret YOU make up (any long random string). It protects your
# MCP server itself so random internet traffic can't call it.
# You will paste this same value into Claude's "Authorization" / OAuth
# bearer token field when you add the custom connector, OR use the
# X-MCP-Server-Key header approach described in README.md.
MCP_SERVER_KEY=change_me_to_a_long_random_string

# --- GHL credentials ---
# GHL_PIT: GoHighLevel Private Integration Token, created in the sub-account
# under Settings > Private Integrations. Needs scopes calendars/events.write,
# calendars/events.readonly, and contacts.write.
GHL_PIT=your_ghl_private_integration_token_here
# GHL_LOC: the GHL location (sub-account) id these API calls act on.
GHL_LOC=your_ghl_location_id_here
GHL_API_BASE=https://services.leadconnectorhq.com

# GHL_WEBHOOK_SECRET: a secret YOU make up. Configure the GHL Workflow's
# "Webhook" action to send this as `Authorization: Bearer <value>` so
# POST /webhooks/ghl/booking can verify the request actually came from GHL.
GHL_WEBHOOK_SECRET=change_me_to_a_long_random_string

# WORKIZ_WEBHOOK_SECRET: a secret YOU make up. Configure the Workiz webhook
# (job created/updated) to send this as `Authorization: Bearer <value>` so
# POST /webhooks/workiz/job can verify the request actually came from Workiz.
WORKIZ_WEBHOOK_SECRET=change_me_to_a_long_random_string

# --- Misc ---
PORT=3000

# Optional: comma-separated list of Workiz job statuses you consider
# "needs review" for the reclassification helper tool
REVIEW_STATUSES=Unscheduled,Pending

# Optional: IANA timezone for converting between Workiz's naive local
# datetimes and GHL's ISO/UTC datetimes. Defaults to America/New_York.
# WORKIZ_TIMEZONE=America/New_York

# Optional: where the Workiz-UUID -> GHL-block-event-id JSON file lives.
# Defaults to ./data/ghl-block-map.json. On Render, point this at a mounted
# persistent disk if you need it to survive redeploys.
# GHL_BLOCK_STORE_PATH=/var/data/ghl-block-map.json
